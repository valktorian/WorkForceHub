{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Gateway": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "http://localhost:4200"
      ]
    }
  },
  "Jwt": {
    "Issuer": "WorkForceHub",
    "Audience": "WorkForceHub.Client",
    "SecretKey": "",
    "ExpirationMinutes": 60
  },
  "Downstream": {
    "AccountCommand": {
      "Host": "localhost",
      "Port": 5222
    },
    "AccountQuery": {
      "Host": "localhost",
      "Port": 5115
    },
    "ProfileCommand": {
      "Host": "localhost",
      "Port": 5062
    },
    "ProfileQuery": {
      "Host": "localhost",
      "Port": 5003
    },
    "TimeCommand": {
      "Host": "localhost",
      "Port": 5033
    },
    "TimeQuery": {
      "Host": "localhost",
      "Port": 5257
    },
    "EvolutionCommand": {
      "Host": "localhost",
      "Port": 5049
    },
    "EvolutionQuery": {
      "Host": "localhost",
      "Port": 5011
    },
    "Media": {
      "Host": "localhost",
      "Port": 5199
    }
  },
  "SwaggerSources": {
    "account-command": [ "http://localhost:5222/swagger/v1/swagger.json" ],
    "account-query": [ "http://localhost:5115/swagger/v1/swagger.json" ],
    "profile-command": [ "http://localhost:5062/swagger/v1/swagger.json" ],
    "profile-query": [ "http://localhost:5003/swagger/v1/swagger.json" ],
    "time-command": [ "http://localhost:5033/swagger/v1/swagger.json" ],
    "time-query": [ "http://localhost:5257/swagger/v1/swagger.json" ],
    "evolution-command": [ "http://localhost:5049/swagger/v1/swagger.json" ],
    "evolution-query": [ "http://localhost:5011/swagger/v1/swagger.json" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "QuotaExceededResponse": {
      "Content": "{\"message\": \"Too many requests. Please slow down.\"}",
      "ContentType": "application/json",
      "StatusCode": 429
    },
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      {
        "Ip": "127.0.0.1",
        "Rules": [
          {
            "Endpoint": "/api/account/*",
            "Period": "1m",
            "Limit": 30
          }
        ]
      }
    ],
    "ClientRules": [
      {
        "ClientId": "trusted-client",
        "Rules": [
          {
            "Endpoint": "*",
            "Period": "1m",
            "Limit": 1000
          }
        ]
      }
    ]
  }
}
